{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "/**": "allow"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "appsettings.json": "deny",
      "**/appsettings.json": "deny",
      "appsettings.*.json": "deny",
      "**/appsettings.*.json": "deny",
      "appsetttings.*.json": "deny",
      "**/appsetttings.*.json": "deny"
    }
  }
}
